<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BoxingRoundApp.ViewModel"
             x:Class="BoxingRoundApp.Views.ActivateWorkoutProfilePage"
             BackgroundColor="#121212"
             Title="Ready to Work?">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="15">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
            <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
                <Label Text="TOTAL TIME:" FontSize="10" TextColor="Gray" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Text="{Binding Profile.TotalTime}" TextColor="#FACC15" FontAttributes="Bold" FontSize="18" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Button Grid.Column="1"
                    Text="EDIT"
                    Command="{Binding EditRoundsCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#E11D48"
                    FontAttributes="Bold"
                    FontSize="12"
                    BorderWidth="1"
                    BorderColor="#E11D48"
                    HeightRequest="40"
                    Padding="15,0"
                    CornerRadius="8"/>
        </Grid>

        <Border Grid.Row="1" 
                Margin="0,10" 
                Padding="20" 
                BackgroundColor="#1E1E1E" 
                Stroke="#333333" 
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Label Text="{Binding Profile.Name, Converter={StaticResource UpperCaseConverter}}"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="2"/>
        </Border>

        <CollectionView ItemsSource="{Binding Rounds}" Grid.Row="2" Margin="0,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="15" BackgroundColor="#1E1E1E" Stroke="#222222">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="40, *, Auto" RowDefinitions="Auto, Auto" RowSpacing="10">
                            <Border Grid.Column="0" Grid.Row="0" BackgroundColor="#333333" WidthRequest="30" HeightRequest="30">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15" />
                                </Border.StrokeShape>
                                <Label Text="{Binding RoundNumber}" TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <HorizontalStackLayout Grid.Column="1" Grid.Row="0" Margin="10,0" Spacing="10" VerticalOptions="Center">
                                <Label Text="{Binding DurationSeconds, StringFormat='{0}s WORK'}" TextColor="White" FontSize="14" FontAttributes="Bold" />
                                <Label Text="|" TextColor="#333333" />
                                <Label Text="{Binding RestSeconds, StringFormat='{0}s REST'}" TextColor="Gray" FontSize="14" />
                            </HorizontalStackLayout>

                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" BackgroundColor="#121212" Padding="10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding RoundDescription}" 
                                       TextColor="#FACC15" 
                                       FontSize="14" 
                                       FontAttributes="Italic"
                                       LineBreakMode="WordWrap"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="3" HorizontalOptions="Center" Margin="0,10,0,20">
            <Button Text="START"
                     Command="{Binding StartWorkoutCommand}"
                     BackgroundColor="#E11D48"
                     TextColor="White"
                     FontAttributes="Bold"
                     FontSize="24"
                     HeightRequest="120"
                     WidthRequest="120"
                     CornerRadius="50">
                <Button.Shadow>
                    <Shadow Brush="#E11D48" Offset="0,0" Radius="15" Opacity="0.6" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

    </Grid>
</ContentPage>