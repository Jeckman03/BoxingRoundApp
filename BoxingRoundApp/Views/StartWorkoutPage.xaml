<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="BoxingRoundApp.Views.StartWorkoutPage"
             BackgroundColor="#121212"
             Title="Workout in Progress">

    <Border Margin="10,5" Padding="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20" />
        </Border.StrokeShape>

        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2C2C2C" Offset="0.1" />
                            <GradientStop Color="#1E1E1E" Offset="1.0" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsWorkPhase}" Value="True">
                        <Setter Property="Background" Value="#1B5E20" />
                        <Setter Property="Stroke" Value="#4CAF50" />
                        <Setter Property="StrokeThickness" Value="2" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding CurrentPhase}" Value="Rest">
                        <Setter Property="Background" Value="#37474F" />
                        <Setter Property="Stroke" Value="#90A4AE" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="20">

            <toolkit:MediaElement x:Name="HiddenPlayer" ShouldAutoPlay="False" IsVisible="False" />

            <Label Grid.Row="0"
               Text="{Binding CurrentPhase, Converter={StaticResource UpperCaseConverter}}"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"
               CharacterSpacing="2" />

            <VerticalStackLayout Grid.Row="1" VerticalOptions="Center">
                <Label Text="{Binding FormattedTime}"
                   TextColor="{Binding TimerColor}"
                   FontSize="140"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                    <Label.Shadow>
                        <Shadow Brush="Black" Offset="5,5" Radius="10" Opacity="0.5" />
                    </Label.Shadow>
                </Label>
            </VerticalStackLayout>

            <Border Grid.Row="2" 
                BackgroundColor="#33000000" 
                Padding="15,10" 
                Margin="0,0,0,20"
                HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Label Text="{Binding VisualCombo}"
                   FontSize="26" 
                   FontAttributes="Bold"
                   TextColor="#FACC15" 
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
            </Border>

            <HorizontalStackLayout Grid.Row="3" 
                       HorizontalOptions="Center" 
                       Spacing="20"
                       Margin="0,10,0,20">

                <Button x:Name="PauseButton"
            Text="{Binding PauseButtonText}"
            Command="{Binding TogglePauseCommand}"
            TextColor="White"
            FontAttributes="Bold"
            FontSize="18"
            CharacterSpacing="1"
            CornerRadius="12"
            WidthRequest="150"
            HeightRequest="75"
            BorderWidth="2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="BackgroundColor" Value="#EF6C00" />
                            <Setter Property="BorderColor" Value="#FFB74D" />
                            <Style.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsPaused}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#2E7D32" />
                                    <Setter Property="BorderColor" Value="#81C784" />
                                    <Setter Property="Text" Value="RESUME" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Opacity="0.6" Radius="5" />
                    </Button.Shadow>
                </Button>

                <Button Text="STOP"
            Command="{Binding StopWorkoutCommand}"
            BackgroundColor="#B71C1C"
            TextColor="White"
            FontAttributes="Bold"
            FontSize="18"
            CharacterSpacing="1"
            CornerRadius="12"
            WidthRequest="150"
            HeightRequest="75"
            BorderColor="#E57373"
            BorderWidth="2">
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Opacity="0.6" Radius="5" />
                    </Button.Shadow>
                </Button>

            </HorizontalStackLayout>
        </Grid>
    </Border>

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.95" />
                                <Setter Property="Opacity" Value="0.8" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>
</ContentPage>

