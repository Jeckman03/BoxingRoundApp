<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:sys="clr-namespace:System;assembly=System.Runtime"
               x:Class="BoxingRoundApp.Views.ComboPickerPopup"
               x:TypeArguments="sys:String">

    <VerticalStackLayout BackgroundColor="#212121" 
                         Padding="20" 
                         Spacing="10" 
                         WidthRequest="350">

        <HorizontalStackLayout Spacing="10">
            <Label Text="Current Combo:" TextColor="White" FontAttributes="Bold" VerticalTextAlignment="Center" />
            <Button Text="Clear" 
                Clicked="OnClearClicked" 
                FontSize="10" 
                HeightRequest="30" 
                BackgroundColor="Transparent" 
                TextColor="Gray" />
        </HorizontalStackLayout>

        <Label Text="Current Combo:" TextColor="White" FontAttributes="Bold" />
        <FlexLayout x:Name="PillContainer" Wrap="Wrap" Margin="0,5" />

        <BoxView HeightRequest="1" Color="Gray" Margin="0,10" />

        <Label Text="Tap to Add Hits:" TextColor="White" />
        <FlexLayout x:Name="ButtonsContainer" 
                    Wrap="Wrap" 
                    JustifyContent="Center" />

        <Button Text="SAVE COMBO" 
                Clicked="OnSaveClicked" 
                BackgroundColor="Red" 
                TextColor="White"
                FontAttributes="Bold"
                Margin="0,20,0,0" />
    </VerticalStackLayout>
</toolkit:Popup>